# ── Fabric generated crypto material (contains private keys) ──────────────────
fabric-network/crypto-config/

# ── Channel genesis blocks (regenerated by bootstrap.sh) ──────────────────────
fabric-network/channel-artifacts/

# ── Chaincode package IDs written by deploy-chaincode.sh ──────────────────────
fabric-network/.env

# ── Java / Gradle build and IDE outputs ───────────────────────────────────────
**/build/
**/.gradle/
**/bin/

# Stray compiled class files and JVM crash logs
*.class
hs_err_pid*
replay_pid*

# ── Python virtualenvs / caches ───────────────────────────────────────────────
dlt-package/.venv/
dlt-package/**/__pycache__/
dlt-package/**/*.pyc
dlt-package/dist/
dlt-package/*.egg-info/
